generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  name          String
  phone         String?
  role          Role          @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  agency        Agency?
  appointments  Appointment[] @relation("CustomerAppointments")
  driver        Driver?
  sessions      Session[]
  staff         Staff?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]
}

model Service {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  duration            Int
  price               Float
  isActive            Boolean              @default(true)
  categoryId          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  agencyServices      AgencyService[]
  appointments        Appointment[]
  appointmentServices AppointmentService[]
  category            ServiceCategory?     @relation(fields: [categoryId], references: [id])
  staffServices       StaffService[]
}

model Staff {
  id              String         @id @default(cuid())
  userId          String         @unique
  specializations String[]
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  appointments    Appointment[]
  blockedTimes    BlockedTime[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffServices   StaffService[]
  workingHours    WorkingHours[]
}

model StaffService {
  id        String  @id @default(cuid())
  staffId   String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model WorkingHours {
  id        String   @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

model BlockedTime {
  id        String   @id @default(cuid())
  staffId   String
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Appointment {
  id             String               @id @default(cuid())
  customerId     String?
  staffId        String?
  serviceId      String
  agencyId       String?
  hotelId        String?
  pax            Int?
  customerName   String?
  customerPhone  String?
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus    @default(PENDING)
  notes          String?
  restAmount     Float?
  restCurrency   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  approvalStatus ApprovalStatus       @default(APPROVED)
  agency         Agency?              @relation(fields: [agencyId], references: [id])
  customer       User?                @relation("CustomerAppointments", fields: [customerId], references: [id])
  hotel          Hotel?               @relation(fields: [hotelId], references: [id])
  service        Service              @relation(fields: [serviceId], references: [id])
  staff          Staff?               @relation(fields: [staffId], references: [id])
  services       AppointmentService[]
  transfers      Transfer[]

  @@index([startTime])
  @@index([staffId, startTime])
  @@index([agencyId])
  @@index([approvalStatus])
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  price         Float
  duration      Int
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@index([appointmentId])
}

model Agency {
  id              String          @id @default(cuid())
  userId          String?         @unique
  companyName     String?
  address         String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  code            String          @unique
  commission      Float           @default(0)
  contactName     String?
  email           String?
  name            String
  phone           String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowedServices AgencyService[]
  appointments    Appointment[]
}

model AgencyService {
  id        String   @id @default(cuid())
  agencyId  String
  serviceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  passPrice Float?   @map("paxPrice")
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([agencyId, serviceId])
}

model TimeSlotQuota {
  id        String   @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  maxQuota  Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek, startTime])
}

model Hotel {
  id               String        @id @default(cuid())
  name             String
  address          String?
  distanceToMarina Float?
  regionId         String
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  googleMapsUrl    String?
  lat              Float?
  lng              Float?
  appointments     Appointment[]
  region           Region        @relation(fields: [regionId], references: [id])
}

model Region {
  id                 String              @id @default(cuid())
  name               String              @unique
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  pickupTimeRegionId String?
  pickupTimeRegion   Region?             @relation("RegionTimeMapping", fields: [pickupTimeRegionId], references: [id])
  dependentRegions   Region[]            @relation("RegionTimeMapping")
  hotels             Hotel[]
  sessionTimes       RegionSessionTime[]
}

model RegionSessionTime {
  id        String   @id @default(cuid())
  regionId  String
  time      String
  isActive  Boolean  @default(true)
  maxQuota  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, time])
  @@index([regionId])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Driver {
  id        String     @id @default(cuid())
  userId    String     @unique
  phone     String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transfers Transfer[]
}

model Transfer {
  id            String         @id @default(cuid())
  appointmentId String
  driverId      String?
  status        TransferStatus @default(PENDING)
  pickupTime    DateTime?
  arrivalTime   DateTime?
  departureTime DateTime?
  dropoffTime   DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  driver        Driver?        @relation(fields: [driverId], references: [id])

  @@index([appointmentId])
  @@index([driverId])
  @@index([status])
}

enum Role {
  ADMIN
  STAFF
  AGENCY
  CUSTOMER
  DRIVER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum TransferStatus {
  PENDING
  PICKING_UP
  AT_SPA
  IN_SERVICE
  DROPPING_OFF
  COMPLETED
  CANCELLED
}
